modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[io]]
name = "web"
type = "web"
path = "/"
localPort = 5173

[io.development]
run = "cd artifacts/brew-and-bite && pnpm run dev"

[io.env]
PORT = "5173"
BASE_PATH = "/"
